{
  "geode": "5.7.0",
  "developers": ["miskaa", "MalikHw47"],
  "version": "v1.0.5-beta",
  "description": "cool notification api its so cool",
  "resources": {
    "sprites": [
      "resources/icon-info.png",
      "resources/icon-error.png",
      "resources/icon-success.png",
      "resources/icon-warning.png"
    ],
    "files": [
      "resources/notif.ogg"
    ]
  },
  "id": "miskaa.notif",
  "gd": {
    "win": "2.2081",
    "android": "2.2081",
    "mac": "2.2081",
    "ios": "2.2081"
  },
  "name": "miskaa's notifAPI",
  "tags": ["api"],
  "dependencies": {
    "geode.node-ids": ">=v1.23.3",
    "thesillydoggo.blur-api": ">=v1.0.0"
  },
  "links": {
      "source": "https://github.com/miskkaaa/notif"
  },
  "api": {
    "include": [
      "src/includes/*.hpp",
      "src/includes/**/*.hpp"
    ]
  },
  "settings": {
    "disable-blur": {
      "type": "bool",
      "default": false,
      "name": "disable blur ENTIRELY",
      "description": "Disables blur effects. good for low-end devices."
    }
  }
}